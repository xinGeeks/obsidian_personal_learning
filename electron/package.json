{
  "name": "personal-learning-hub",
  "version": "1.0.0",
  "description": "基于 Obsidian + Deepseek AI 的个人学习平台",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build:frontend": "cd ../frontend && npm run build"
  },
  "build": {
    "appId": "com.personal-learning-hub.app",
    "productName": "Personal Learning Hub",
    "files": [
      "main.js",
      "preload.js",
      "../frontend/dist/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*", "!__pycache__", "!*.pyc", "!.env"]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "express": "^4.21.0"
  }
}
